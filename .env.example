# YouTube Data API v3 key — get one at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" for your project, then create an API key.
YOUTUBE_API_KEY=your_youtube_api_key_here

# Optional: SerpAPI key for cross-platform trend research (Google News / Reddit)
# Get one at https://serpapi.com/ — leave blank to skip web research
SERPAPI_KEY=

# Optional: region code (ISO 3166-1 alpha-2) for trending feed
# Default: US
YT_REGION=US
